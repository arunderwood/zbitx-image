# Force LF line endings on every text file in this repo.
# These files get unpacked into a Linux chroot at build time; CRLF in
# shell scripts, systemd units, or config files breaks runtime behavior.
* text=auto eol=lf

# Be explicit about file types that are LF-only no matter what.
*.sh        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.desktop   text eol=lf
rules.v4    text eol=lf
hostname    text eol=lf
hosts       text eol=lf
