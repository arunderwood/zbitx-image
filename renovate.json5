{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  labels: ["dependencies"],
  dependencyDashboard: true,

  // Submodules aren't picked up by default. Both vendor/pi-gen (the build
  // tooling, pinned to the bookworm-arm64 branch) and vendor/sbitx (the app
  // source) are tracked here.
  "git-submodules": {
    enabled: true,
  },

  // WiringPi .deb pin in pi-gen.config — the version appears twice in the
  // URL (path segment + filename), so two matchStrings.
  //
  // Renovate cannot recompute `ZBITX_WIRINGPI_SHA256` — the build's
  // `sha256sum -c` will fail until a maintainer pushes the new digest
  // onto the bump PR.
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^pi-gen\\.config$/"],
      matchStrings: [
        "ZBITX_WIRINGPI_URL=[^\\n]*?/download/(?<currentValue>[0-9.]+)/",
        "ZBITX_WIRINGPI_URL=[^\\n]*?wiringpi_(?<currentValue>[0-9.]+)_",
      ],
      datasourceTemplate: "github-releases",
      depNameTemplate: "WiringPi/WiringPi",
    },
  ],

  packageRules: [
    {
      matchManagers: ["git-submodules"],
      schedule: ["before 6am on Monday"],
      addLabels: ["submodule"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["github-actions"],
    },
    {
      matchManagers: ["custom.regex"],
      addLabels: ["build-deps"],
    },
    {
      matchDepNames: ["WiringPi/WiringPi"],
      prBodyNotes: [
        "⚠️ Renovate cannot recompute `sha256` for URL-pinned artifacts. After this PR opens, fetch the new `.deb`, compute its sha256, and update the `ZBITX_WIRINGPI_SHA256` line in `pi-gen.config` on this branch — otherwise the build fails at `sha256sum -c`.",
      ],
    },
  ],
}
