{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  labels: ["dependencies"],
  dependencyDashboard: true,

  // Submodules aren't picked up by default. Only vendor/sbitx remains
  // as a submodule (rpi-image-gen now lives as an env var in build.yml).
  "git-submodules": {
    enabled: true,
  },

  // Two URL/env-var pinned deps Renovate can't infer without help:
  //   1. WiringPi .deb in layer/zbitx-sbitx.yaml — version appears twice
  //      in the URL (path segment + filename), so two matchStrings.
  //   2. RPI_IMAGE_GEN_REF in build.yml — picked up via the standard
  //      `# renovate: datasource=… depName=…` annotation directly above it.
  //
  // Renovate cannot recompute `X-Env-Var-wiringpi_sha256` — the build's
  // `sha256sum -c` will fail until a maintainer pushes the new digest
  // onto the bump PR.
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/^layer/zbitx-sbitx\\.yaml$/"],
      matchStrings: [
        "X-Env-Var-wiringpi_url:[^\\n]*?/download/(?<currentValue>[0-9.]+)/",
        "X-Env-Var-wiringpi_url:[^\\n]*?wiringpi_(?<currentValue>[0-9.]+)_",
      ],
      datasourceTemplate: "github-releases",
      depNameTemplate: "WiringPi/WiringPi",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/^\\.github/workflows/[^/]+\\.ya?ml$/"],
      matchStrings: [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+\\S+:\\s*(?<currentValue>\\S+)",
      ],
    },
  ],

  packageRules: [
    {
      matchManagers: ["git-submodules"],
      schedule: ["before 6am on Monday"],
      addLabels: ["submodule"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["github-actions"],
    },
    {
      matchManagers: ["custom.regex"],
      addLabels: ["build-deps"],
    },
    {
      matchDepNames: ["WiringPi/WiringPi"],
      prBodyNotes: [
        "⚠️ Renovate cannot recompute `sha256` for URL-pinned artifacts. After this PR opens, fetch the new `.deb`, compute its sha256, and update the `X-Env-Var-wiringpi_sha256` line on this branch — otherwise the build fails at `sha256sum -c`.",
      ],
    },
  ],
}
