# pi-gen top-level config for the zbitxv2 SDR transceiver image.
#
# Sourced by vendor/pi-gen/build.sh via `-c`. Build it with the wrapper, which
# injects ${ZBITX_ROOT} and the SKIP_IMAGES markers:
#
#     ./scripts/pi-gen-build.sh
#
# Output: vendor/pi-gen/deploy/<date>-zbitx-bookworm.img.xz (+ .info + SBOM).
#
# Named `pi-gen.config` (not pi-gen's default `config`) and passed via `-c`,
# since the wrapper runs build.sh from inside the submodule, not the repo root.
#
# Target: Raspberry Pi Zero 2 W (arm64) running Raspberry Pi OS Desktop
# (Bookworm). The arm64 base comes from pi-gen's bookworm-arm64 branch
# (build.sh hardcodes ARCH there); see vendor/pi-gen pinned in .gitmodules.

# ---- Image identity ----
IMG_NAME="zbitx-bookworm"
PI_GEN_RELEASE="zbitxv2-image"
RELEASE="bookworm"

# ---- First user ----
# zbitxv2 hardcodes /home/pi/sbitx paths (sbitx.c, fft_filter.c), so the user
# MUST stay `pi`. DISABLE_FIRST_BOOT_USER_RENAME=1 keeps it `pi` and removes
# the piwiz first-boot rename wizard. The account is created LOCKED (stage1
# uses `adduser --disabled-password`, and we set no FIRST_USER_PASS) — desktop
# autologin (stage4 sets boot behaviour B4) gets the appliance to its GUI
# without a password, and operators set a password / WiFi / SSH key via
# Raspberry Pi Imager's "Edit settings" before flashing (firstrun.sh +
# userconf.txt, handled by the stock userconf-pi service). Keep the username
# `pi` in Imager.
FIRST_USER_NAME="pi"
DISABLE_FIRST_BOOT_USER_RENAME="1"
ENABLE_SSH="0"

# ---- System identity / locale ----
# US WiFi regulatory domain (matches the project's prior cfg80211 regdom=US).
# Locale/keyboard default to US to match; ham radio logs in UTC. All four are
# overridable from Raspberry Pi Imager at flash time.
TARGET_HOSTNAME="sbitx"
WPA_COUNTRY="US"
LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP="us"
KEYBOARD_LAYOUT="English (US)"
TIMEZONE_DEFAULT="Etc/UTC"

# ---- Deploy ----
# xz is the stock Raspberry Pi OS distribution format and is ingested natively
# by Raspberry Pi Imager (this pinned pi-gen does not offer zstd).
DEPLOY_COMPRESSION="xz"
COMPRESSION_LEVEL="6"

# ---- Stage list ----
# Stock Lite (0-2) + Desktop (3-4), then our delta. stage5 (the "full" image
# with LibreOffice etc.) is intentionally excluded. ${ZBITX_ROOT} is exported
# by scripts/pi-gen-build.sh; ${BASE_DIR} is pi-gen's own dir.
STAGE_LIST="${BASE_DIR}/stage0 ${BASE_DIR}/stage1 ${BASE_DIR}/stage2 ${BASE_DIR}/stage3 ${BASE_DIR}/stage4 ${ZBITX_ROOT}/stage-zbitx"

# ---- zbitx delta vars (consumed by stage-zbitx) ----
# Vendored sbitx submodule (sibling of vendor/pi-gen).
export ZBITX_SRCDIR="${BASE_DIR}/../sbitx"
# WiringPi 3.x .deb (replaces deprecated drogon.net 2.x). arm64 to match the base.
export ZBITX_WIRINGPI_URL="https://github.com/WiringPi/WiringPi/releases/download/3.18/wiringpi_3.18_arm64.deb"
export ZBITX_WIRINGPI_SHA256="95553cde829a976f9a546d59c673e4292eab62869c0c0cd4427f1e78a1aad6c6"
